<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="900.0" spacing="20.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.udistrital.controller.ClientesController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <Label text="5. Directorio de Clientes" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>

        <HBox spacing="15.0" alignment="CENTER_LEFT" style="-fx-background-color: #ecf0f1; -fx-padding: 15px; -fx-background-radius: 5px;">
            <children>
                <VBox spacing="5.0">
                    <Label text="Identificación (CC/NIT):" />
                    <TextField fx:id="txtIdentificador" prefWidth="150.0" promptText="Ej. 10203040" />
                </VBox>
                <VBox spacing="5.0">
                    <Label text="Nombre del Cliente:" />
                    <TextField fx:id="txtNombre" prefWidth="250.0" promptText="Ej. Juan Pérez" />
                </VBox>
                <VBox spacing="5.0">
                    <Label text="Tipo de Cliente:" />
                    <ComboBox fx:id="cmbTipoCliente" prefWidth="150.0" />
                </VBox>
                <VBox alignment="BOTTOM_LEFT">
                    <Button text="Registrar Cliente" onAction="#registrarCliente" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold;"/>
                </VBox>
            </children>
        </HBox>

        <TableView fx:id="tablaClientes" prefHeight="400.0" prefWidth="860.0" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                <TableColumn fx:id="colIdentificador" prefWidth="150.0" text="Identificación" />
                <TableColumn fx:id="colNombre" prefWidth="300.0" text="Nombre Completo" />
                <TableColumn fx:id="colTipo" prefWidth="150.0" text="Categoría (Tipo)" />
            </columns>
        </TableView>
    </children>
</VBox>