<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="650.0" prefWidth="1000.0" spacing="15.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.udistrital.controller.SolicitudesController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <Label text="1. Gestión de Emergencias" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>

        <HBox spacing="10.0" alignment="CENTER_LEFT" style="-fx-background-color: #ecf0f1; -fx-padding: 15px; -fx-background-radius: 5px;">
            <children>
                <VBox spacing="5.0">
                    <Label text="ID Cliente (CC/NIT):" />
                    <TextField fx:id="txtIdCliente" prefWidth="120.0" promptText="Num Cliente" />
                </VBox>
                <VBox spacing="5.0">
                    <Label text="Tipo Emergencia:" />
                    <ComboBox fx:id="cmbTipo" prefWidth="150.0" />
                </VBox>
                <VBox spacing="5.0">
                    <Label text="Criticidad:" />
                    <ComboBox fx:id="cmbCriticidad" prefWidth="120.0" />
                </VBox>
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Descripción de la Incidencia:" />
                    <TextField fx:id="txtDescripcion" />
                </VBox>
                <VBox alignment="BOTTOM_LEFT">
                    <Button text="Registrar Caso" onAction="#registrarSolicitud" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;"/>
                </VBox>
            </children>
        </HBox>

        <TableView fx:id="tablaSolicitudes" prefHeight="300.0" prefWidth="960.0" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" prefWidth="40.0" text="ID" />
                <TableColumn fx:id="colTipo" prefWidth="150.0" text="Tipo Emergencia" />
                <TableColumn fx:id="colCriticidad" prefWidth="100.0" text="Criticidad" />
                <TableColumn fx:id="colEstado" prefWidth="120.0" text="Estado" />
                <TableColumn fx:id="colTecnico" prefWidth="80.0" text="Técnico" />
                <TableColumn fx:id="colUnidad" prefWidth="100.0" text="Unidad" />
                <TableColumn fx:id="colDescripcion" prefWidth="300.0" text="Descripción" />
            </columns>
        </TableView>

        <HBox spacing="20.0">
            <children>
                <VBox spacing="10.0" style="-fx-background-color: #fcf3cf; -fx-padding: 10px; -fx-background-radius: 5px;" HBox.hgrow="ALWAYS">
                    <Label text="Panel de Despacho (Asignar Recursos)" style="-fx-font-weight: bold; -fx-text-fill: #d35400;"/>
                    <HBox spacing="10.0" alignment="CENTER_LEFT">
                        <ComboBox fx:id="cmbTecnicosDisponibles" promptText="Técnico Disponible" prefWidth="180.0"/>
                        <ComboBox fx:id="cmbUnidadesDisponibles" promptText="Unidad Disponible" prefWidth="180.0"/>
                        <CheckBox fx:id="chkRequiereKit" text="Llevar Kit"/>
                        <Button text="Despachar Servicio" onAction="#despacharSolicitud" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold;"/>
                    </HBox>
                </VBox>
              
                <VBox spacing="10.0" style="-fx-background-color: #d5f5e3; -fx-padding: 10px; -fx-background-radius: 5px;" HBox.hgrow="ALWAYS">
                    <Label text="Panel de Cierre" style="-fx-font-weight: bold; -fx-text-fill: #1e8449;"/>
                    <HBox spacing="10.0" alignment="CENTER_LEFT">
                        <CheckBox fx:id="chkKitDanado" text="¿Kit averiado en servicio?"/>
                        <Button text="Finalizar Caso" onAction="#finalizarSolicitud" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>
                    </HBox>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>