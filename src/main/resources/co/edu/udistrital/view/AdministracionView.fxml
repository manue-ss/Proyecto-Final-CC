<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="900.0" spacing="20.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.udistrital.controller.AdministracionController">
   <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
   <children>
      <Label text="6. Panel de Auditoría y Reportes" textFill="#2c3e50">
         <font><Font name="System Bold" size="24.0" /></font>
      </Label>

      <TableView fx:id="tablaAuditoria" prefHeight="500.0" prefWidth="860.0" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="colId" prefWidth="200.0" text="ID Operación" />
          <TableColumn fx:id="colTipo" prefWidth="250.0" text="Tipo de Operación" />
          <TableColumn fx:id="colDescripcion" prefWidth="350.0" text="Detalles del Movimiento" />
        </columns>
      </TableView>

      <HBox spacing="10.0" alignment="CENTER_RIGHT">
         <children>
            <Button text="↩ Deshacer Última Operación" onAction="#deshacerOperacion" style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-weight: bold;"/>
            <Button text="⬇ Exportar Reporte CSV" onAction="#exportarCSV" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;"/>
         </children>
      </HBox>
   </children>
</VBox>