<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="900.0" spacing="20.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.udistrital.controller.SolicitudesController">
   <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
   <children>
      <Label text="1. Gestión de Emergencias" textFill="#2c3e50">
         <font><Font name="System Bold" size="24.0" /></font>
      </Label>
      
      <TableView fx:id="tablaSolicitudes" prefHeight="500.0" prefWidth="860.0" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
          <TableColumn fx:id="colTipo" prefWidth="160.0" text="Tipo de Emergencia" />
          <TableColumn fx:id="colCriticidad" prefWidth="120.0" text="Criticidad" />
          <TableColumn fx:id="colEstado" prefWidth="120.0" text="Estado Actual" />
          <TableColumn fx:id="colDescripcion" prefWidth="300.0" text="Descripción del Incidente" />
        </columns>
      </TableView>
      
   </children>
</VBox>