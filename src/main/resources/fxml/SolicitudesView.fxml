<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="900.0" spacing="20.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.udistrital.controller.SolicitudesController">
   <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
   <children>
      <Label text="1. Gestión de Emergencias" textFill="#2c3e50">
         <font><Font name="System Bold" size="24.0" /></font>
      </Label>

      <HBox spacing="10.0" alignment="CENTER_LEFT" style="-fx-background-color: #ecf0f1; -fx-padding: 15px; -fx-background-radius: 5px;">
         <children>
            <VBox spacing="5.0">
               <Label text="ID Cliente:" />
               <TextField fx:id="txtIdCliente" prefWidth="80.0" promptText="Num" />
            </VBox>
            <VBox spacing="5.0">
               <Label text="Tipo Emergencia:" />
               <ComboBox fx:id="cmbTipo" prefWidth="150.0" />
            </VBox>
            <VBox spacing="5.0">
               <Label text="Criticidad:" />
               <ComboBox fx:id="cmbCriticidad" prefWidth="130.0" />
            </VBox>
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
               <Label text="Descripción de la Incidencia:" />
               <TextField fx:id="txtDescripcion" />
            </VBox>
            <VBox alignment="BOTTOM_LEFT">
               <Button text="Registrar" onAction="#registrarSolicitud" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;"/>
            </VBox>
         </children>
      </HBox>

      <TableView fx:id="tablaSolicitudes" prefHeight="400.0" prefWidth="860.0" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
          <TableColumn fx:id="colTipo" prefWidth="180.0" text="Tipo de Emergencia" />
          <TableColumn fx:id="colCriticidad" prefWidth="120.0" text="Criticidad" />
          <TableColumn fx:id="colEstado" prefWidth="120.0" text="Estado Actual" />
          <TableColumn fx:id="colDescripcion" prefWidth="350.0" text="Descripción" />
        </columns>
      </TableView>

      <HBox spacing="10.0" alignment="CENTER_RIGHT">
         <children>
            <Button text="Marcar como 'En Ejecución'" onAction="#marcarEnEjecucion" style="-fx-background-color: #f39c12; -fx-text-fill: white;"/>
            <Button text="Marcar como 'Atendida'" onAction="#finalizarSolicitud" style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
         </children>
      </HBox>
   </children>
</VBox>